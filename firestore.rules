rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Reads the caller's Firestore profile to check role.
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    // Blocked users cannot access any data
    function isNotBlocked() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) == false;
    }

    // Family member access: checks if the requesting user's phone number
    // is an active family member linked to the given userId.
    function isFamilyOf(userId) {
      let phone = request.auth.token.phone_number;
      return phone != null
        && exists(/databases/$(database)/documents/family_access/$(phone))
        && get(/databases/$(database)/documents/family_access/$(phone)).data.linkedUserId == userId
        && get(/databases/$(database)/documents/family_access/$(phone)).data.status == 'active';
    }

    // ── users ─────────────────────────────────────────────────────────────
    // NOTE: this document is broadly readable (any non-blocked authenticated
    // user) because profile browsing is core to the product. Sensitive PII
    // (phone, email, KYC document numbers/scans) therefore must NEVER live
    // on this document — see users/{userId}/private/{contact|kyc} below.
    match /users/{userId} {
      allow read: if isAuth() && (isOwner(userId) || isAdmin() || isNotBlocked() || isFamilyOf(userId));

      allow create: if isAuth()
        && isOwner(userId)
        && !('role' in request.resource.data)
        && !('phone' in request.resource.data)
        && !('email' in request.resource.data)
        && !('kycDocumentType' in request.resource.data)
        && !('kycDocumentNumber' in request.resource.data)
        && !('kycDocumentUrl' in request.resource.data)
        && request.resource.data.get('isVerified', false) == false
        && request.resource.data.get('isPremium', false) == false
        && request.resource.data.get('isBlocked', false) == false
        && request.resource.data.get('kycStatus', 'not_started') in ['not_started', 'submitted']
        && request.resource.data.get('photos', []).size() <= 5;

      allow update: if isAuth() && (
        isAdmin()
        ||
        (
          isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(
               ['role', 'isVerified', 'isBlocked', 'phone', 'email',
                'kycDocumentType', 'kycDocumentNumber', 'kycDocumentUrl']
             )
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isPremium'])
            || request.resource.data.isPremium == false
          )
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['premiumPlan'])
            || request.resource.data.premiumPlan == 'none'
          )
          && (
            !request.resource.data.diff(resource.data).affectedKeys().hasAny(['kycStatus'])
            || request.resource.data.kycStatus in ['not_started', 'submitted']
          )
          // Absolute ceiling — the free/premium 2-vs-5 split is a UI-level
          // convention today (Settings.jsx), not yet server-enforced per
          // tier; this only stops writes past the hard maximum any tier
          // is ever allowed to have.
          && request.resource.data.get('photos', []).size() <= 5
        )
      );

      allow delete: if isAdmin();

      // ── users/{userId}/private/{contact|kyc} ──────────────────────────
      // phone/email and KYC document data live here instead of on the
      // broadly-readable parent doc. Only the owner and admins can read
      // this directly. A matched user's contact card is revealed only
      // once a mutual 'accepted' interest exists between the two users —
      // checked here server-side via the deterministic interest doc ID
      // (senderId_receiverId), never trusted from client-side UI gating.
      match /private/{docId} {
        allow read: if isAuth() && (
          isOwner(userId)
          || isAdmin()
          || (
            docId == 'contact' &&
            (
              (
                exists(/databases/$(database)/documents/interests/$(request.auth.uid + '_' + userId))
                && get(/databases/$(database)/documents/interests/$(request.auth.uid + '_' + userId)).data.status == 'accepted'
              )
              ||
              (
                exists(/databases/$(database)/documents/interests/$(userId + '_' + request.auth.uid))
                && get(/databases/$(database)/documents/interests/$(userId + '_' + request.auth.uid)).data.status == 'accepted'
              )
            )
          )
        );

        allow create: if isAuth() && isOwner(userId) && docId in ['contact', 'kyc'];
        allow update: if isAuth() && (isOwner(userId) || isAdmin()) && docId in ['contact', 'kyc'];
        allow delete: if isAdmin();
      }
    }

    // ── interests ─────────────────────────────────────────────────────────
    match /interests/{interestId} {
      allow read: if isAuth() && (
        resource.data.senderId == request.auth.uid
        || resource.data.receiverId == request.auth.uid
        || isFamilyOf(resource.data.senderId)
        || isFamilyOf(resource.data.receiverId)
      );

      allow create: if isAuth()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.status == 'pending'
        // Deterministic ID lets the private/contact rule above verify a
        // mutual accepted interest via exists()/get() without a query.
        && interestId == request.resource.data.senderId + '_' + request.resource.data.receiverId;

      allow update: if isAuth()
        && resource.data.receiverId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['accepted', 'declined'];

      allow delete: if isAdmin()
        || (isAuth() && (
          resource.data.senderId == request.auth.uid ||
          resource.data.receiverId == request.auth.uid
        ));
    }

    // ── shortlists ────────────────────────────────────────────────────────
    // Family members can read/create/delete shortlists for their linked user.
    // Profile owners can read (to count how many people shortlisted them).
    match /shortlists/{shortlistId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid
        || isFamilyOf(resource.data.userId)
        || resource.data.profileId == request.auth.uid
      );

      allow create: if isAuth() && (
        request.resource.data.userId == request.auth.uid
        || isFamilyOf(request.resource.data.userId)
      );

      allow update: if false;

      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid
        || isFamilyOf(resource.data.userId)
      );
    }

    // ── chats ─────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuth()
        && request.auth.uid in resource.data.participants;

      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participants;

      allow update: if isAuth()
        && request.auth.uid in resource.data.participants;

      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;

        allow update: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && request.resource.data.status == 'read';

        allow delete: if false;
      }
    }

    // ── family_access ─────────────────────────────────────────────────────
    // Document ID = phone number (e.g. "+919876543210").
    // Owner (linkedUserId) manages their family members.
    // Family member can read their own entry (for login detection).
    match /family_access/{phone} {
      allow read: if isAuth() && (
        resource.data.linkedUserId == request.auth.uid
        || request.auth.token.phone_number == phone
      );
      allow create: if isAuth() && request.resource.data.linkedUserId == request.auth.uid;
      allow update: if isAuth() && resource.data.linkedUserId == request.auth.uid;
      allow delete: if isAdmin() || (isAuth() && resource.data.linkedUserId == request.auth.uid);
    }

    // ── password_index ────────────────────────────────────────────────────
    // Read locked: lookup is done server-side via verifyRsLogin Cloud Function (admin SDK).
    // Write locked: hashing (scrypt + per-user salt) happens only inside the
    // setRsPassword Cloud Function (admin SDK bypasses these rules) — no
    // client may ever write a password hash directly.
    match /password_index/{rsId} {
      allow read: if false;
      allow create, update: if false;
      allow delete: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
    }

    // ── smart_match_sent ──────────────────────────────────────────────────
    // Tracks which existing-user/new-user pairs have been notified.
    // Doc ID: {existingUserId}_{newUserId} — immutable once created.
    match /smart_match_sent/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ── smart_match_daily ─────────────────────────────────────────────────
    // Per-user daily notification counter — prevents spam.
    // Doc ID: {userId}_{YYYY-MM-DD}
    match /smart_match_daily/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── shaadi_requests ───────────────────────────────────────────────────
    // Doc ID = chatId. Tracks marriage confirmation between two matched users.
    match /shaadi_requests/{chatId} {
      allow read: if isAuth() && (
        resource.data.initiatorId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
      allow create: if isAuth() && request.resource.data.initiatorId == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.receiverId == request.auth.uid ||
        resource.data.initiatorId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ── success_stories ───────────────────────────────────────────────────
    match /success_stories/{storyId} {
      allow read: if
        (resource.data.status == 'approved' && resource.data.isPublic == true)
        || (isAuth() && (
          resource.data.userId1 == request.auth.uid
          || resource.data.userId2 == request.auth.uid
        ))
        || isAdmin();
      allow create: if isAuth() && (
        request.resource.data.userId1 == request.auth.uid ||
        request.resource.data.userId2 == request.auth.uid
      );
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── analytics ─────────────────────────────────────────────────────────
    // Only the profile owner can read their own analytics.
    // Any authenticated user can create/update — but non-owners may only
    // touch the view-count fields.
    match /analytics/{userId} {
      allow read: if isAuth() && isOwner(userId);

      allow create: if isAuth();

      allow update: if isAuth() && (
        isOwner(userId)
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['profileViews', 'weeklyViews', 'lastUpdated'])
      );
    }

    // ── notifications ─────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;

      allow create: if isAuth() && (
        // User-to-user notifications (interests, chat, family activity, smart match)
        request.resource.data.fromId == request.auth.uid
        // Admin notifications (KYC approved/rejected) — only real admins
        || (isAdmin() && request.resource.data.fromId == 'admin')
        // System self-notifications (KYC submitted) — only sender can notify themselves
        || (request.resource.data.fromId == 'system'
            && request.resource.data.userId == request.auth.uid)
      );

      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'read';

      allow delete: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);
    }

  }
}
