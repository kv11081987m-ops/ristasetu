rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Reads the caller's Firestore profile to check role.
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    // Blocked users cannot access any data
    function isNotBlocked() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) == false;
    }

    // ── users ─────────────────────────────────────────────────────────────
    // Any authenticated user can read profiles (needed for browsing/search).
    // Only the owner can write their own document.
    // Users CANNOT change their own `role` field — only admins can.
    match /users/{userId} {
      allow read: if isAuth() && (isOwner(userId) || isAdmin() || isNotBlocked());

      allow create: if isAuth()
        && isOwner(userId)
        && !('role' in request.resource.data);

      allow update: if isAuth() && (
        // Owner can update their own profile but cannot touch 'role'
        (isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        ||
        // Admin can update any profile (for verification / KYC)
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ── interests ─────────────────────────────────────────────────────────
    // Users can only read interests where they are sender or receiver.
    // Client queries MUST include a where('senderId','==',uid) or
    // where('receiverId','==',uid) filter to satisfy Firestore's query rules.
    match /interests/{interestId} {
      allow read: if isAuth()
        && (resource.data.senderId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);

      // Only the sender can create; status must start as 'pending'
      allow create: if isAuth()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.status == 'pending';

      // Only the receiver can accept/decline (change status only)
      allow update: if isAuth()
        && resource.data.receiverId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['accepted', 'declined'];

      // User can delete interests they are part of (needed for account deletion)
      allow delete: if isAdmin()
        || (isAuth() && (
          resource.data.senderId == request.auth.uid ||
          resource.data.receiverId == request.auth.uid
        ));
    }

    // ── shortlists ────────────────────────────────────────────────────────
    // Users can only see and manage their own shortlist entries.
    match /shortlists/{shortlistId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;

      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid;

      allow update: if false; // shortlists are create/delete only

      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── chats ─────────────────────────────────────────────────────────────
    // Only participants in a chat can read or write.
    match /chats/{chatId} {
      allow read: if isAuth()
        && request.auth.uid in resource.data.participants;

      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participants;

      // Participants can update metadata (lastMessage preview) only
      allow update: if isAuth()
        && request.auth.uid in resource.data.participants;

      allow delete: if isAdmin();

      // Messages are stored as a subcollection — no more 1MB document limit
      match /messages/{msgId} {
        allow read: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;

        // Participants can mark a received message as 'read' (for read receipts)
        allow update: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && request.resource.data.status == 'read';

        allow delete: if false;
      }
    }

    // ── password_index ────────────────────────────────────────────────────
    // Public read (needed for unauthenticated RS ID + password login lookup).
    // Only the uid owner can write their own entry.
    match /password_index/{rsId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow delete: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
    }

    // ── notifications ─────────────────────────────────────────────────────
    // Each user can only read their own notifications.
    // Any authenticated user can create a notification for another user.
    // Only the recipient can mark as read (update status field only).
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;

      allow create: if isAuth()
        && request.resource.data.fromId == request.auth.uid;

      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'read';

      // Recipient can delete their own notifications (needed for account deletion)
      allow delete: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);
    }

  }
}
