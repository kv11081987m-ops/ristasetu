rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Reads the caller's Firestore profile to check role.
    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', '') == 'admin';
    }

    // Blocked users cannot access any data
    function isNotBlocked() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isBlocked', false) == false;
    }

    // Family member access: checks if the requesting user's phone number
    // is an active family member linked to the given userId.
    function isFamilyOf(userId) {
      let phone = request.auth.token.phone_number;
      return phone != null
        && exists(/databases/$(database)/documents/family_access/$(phone))
        && get(/databases/$(database)/documents/family_access/$(phone)).data.linkedUserId == userId
        && get(/databases/$(database)/documents/family_access/$(phone)).data.status == 'active';
    }

    // ── users ─────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuth() && (isOwner(userId) || isAdmin() || isNotBlocked() || isFamilyOf(userId));

      allow create: if isAuth()
        && isOwner(userId)
        && !('role' in request.resource.data);

      allow update: if isAuth() && (
        (isOwner(userId)
          && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']))
        ||
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // ── interests ─────────────────────────────────────────────────────────
    match /interests/{interestId} {
      allow read: if isAuth() && (
        resource.data.senderId == request.auth.uid
        || resource.data.receiverId == request.auth.uid
        || isFamilyOf(resource.data.senderId)
        || isFamilyOf(resource.data.receiverId)
      );

      allow create: if isAuth()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update: if isAuth()
        && resource.data.receiverId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status in ['accepted', 'declined'];

      allow delete: if isAdmin()
        || (isAuth() && (
          resource.data.senderId == request.auth.uid ||
          resource.data.receiverId == request.auth.uid
        ));
    }

    // ── shortlists ────────────────────────────────────────────────────────
    // Family members can read/create/delete shortlists for their linked user.
    // Profile owners can read (to count how many people shortlisted them).
    match /shortlists/{shortlistId} {
      allow read: if isAuth() && (
        resource.data.userId == request.auth.uid
        || isFamilyOf(resource.data.userId)
        || resource.data.profileId == request.auth.uid
      );

      allow create: if isAuth() && (
        request.resource.data.userId == request.auth.uid
        || isFamilyOf(request.resource.data.userId)
      );

      allow update: if false;

      allow delete: if isAuth() && (
        resource.data.userId == request.auth.uid
        || isFamilyOf(resource.data.userId)
      );
    }

    // ── chats ─────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isAuth()
        && request.auth.uid in resource.data.participants;

      allow create: if isAuth()
        && request.auth.uid in request.resource.data.participants;

      allow update: if isAuth()
        && request.auth.uid in resource.data.participants;

      allow delete: if isAdmin();

      match /messages/{msgId} {
        allow read: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;

        allow create: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.senderId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 2000;

        allow update: if isAuth()
          && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
          && request.resource.data.status == 'read';

        allow delete: if false;
      }
    }

    // ── family_access ─────────────────────────────────────────────────────
    // Document ID = phone number (e.g. "+919876543210").
    // Owner (linkedUserId) manages their family members.
    // Family member can read their own entry (for login detection).
    match /family_access/{phone} {
      allow read: if isAuth() && (
        resource.data.linkedUserId == request.auth.uid
        || request.auth.token.phone_number == phone
      );
      allow create: if isAuth() && request.resource.data.linkedUserId == request.auth.uid;
      allow update: if isAuth() && resource.data.linkedUserId == request.auth.uid;
      allow delete: if isAdmin() || (isAuth() && resource.data.linkedUserId == request.auth.uid);
    }

    // ── password_index ────────────────────────────────────────────────────
    match /password_index/{rsId} {
      allow read: if true;
      allow create: if isAuth() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuth() && resource.data.uid == request.auth.uid;
      allow delete: if isAdmin() || (isAuth() && resource.data.uid == request.auth.uid);
    }

    // ── smart_match_sent ──────────────────────────────────────────────────
    // Tracks which existing-user/new-user pairs have been notified.
    // Doc ID: {existingUserId}_{newUserId} — immutable once created.
    match /smart_match_sent/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }

    // ── smart_match_daily ─────────────────────────────────────────────────
    // Per-user daily notification counter — prevents spam.
    // Doc ID: {userId}_{YYYY-MM-DD}
    match /smart_match_daily/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

    // ── analytics ─────────────────────────────────────────────────────────
    // Only the profile owner can read their own analytics.
    // Any authenticated user can create/update — but non-owners may only
    // touch the view-count fields.
    match /analytics/{userId} {
      allow read: if isAuth() && isOwner(userId);

      allow create: if isAuth();

      allow update: if isAuth() && (
        isOwner(userId)
        || request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['profileViews', 'weeklyViews', 'lastUpdated'])
      );
    }

    // ── notifications ─────────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if isAuth() && resource.data.userId == request.auth.uid;

      allow create: if isAuth()
        && request.resource.data.fromId == request.auth.uid;

      allow update: if isAuth()
        && resource.data.userId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'read';

      allow delete: if isAdmin()
        || (isAuth() && resource.data.userId == request.auth.uid);
    }

  }
}
