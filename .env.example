# Separate SIGNED preset for KYC document uploads (Aadhaar/PAN/etc scans).
# Must be created in the Cloudinary dashboard with Signed mode + delivery
# type "authenticated" so documents aren't publicly viewable by URL alone.
# Upload signatures are generated server-side (see functions/index.js
# getKycUploadSignature) — this value only names which preset to target.
VITE_CLOUDINARY_KYC_PRESET=
